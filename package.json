{
  "name": "@hoodx/sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for the HoodX API",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HoodX-Live/sdk-ts.git"
  },
  "homepage": "https://github.com/HoodX-Live/sdk-ts#readme",
  "bugs": {
    "url": "https://github.com/HoodX-Live/sdk-ts/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "pnpm generate && pnpm build && pnpm test && git diff --exit-code",
    "generate": "openapi-ts",
    "prepack": "pnpm build",
    "test": "node --test test/*.test.cjs"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.98.2",
    "typescript": "6.0.3"
  }
}
